# DeepRant 模型配置文件示例
# 请复制此文件为 .env 并填入你的 API 密钥
# .env 文件不会被上传到 git (已在 .gitignore 中)

# DeepSeek 模型 API 密钥
# 获取地址: https://api-inference.modelscope.cn/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek-OCR 模型 API 密钥
# 获取地址: https://www.siliconflow.cn/
DEEPSEEK_OCR_API_KEY=your_deepseek_ocr_api_key_here

# GLM 模型 API 密钥
# 获取地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
